# Client: set this to the public URL of the realtime Socket.IO server.
# Local default is http://localhost:3001.
VITE_MULTIPLAYER_SERVER_URL=http://localhost:3001
# Production example for the Vercel frontend:
# VITE_MULTIPLAYER_SERVER_URL=https://your-void-arena-realtime-server.example.com

# Realtime server
PORT=3001
HOST=0.0.0.0

# Use your Vercel domain in production, for example:
# CLIENT_ORIGIN=https://void-arena.vercel.app
# CLIENT_ORIGINS=https://void-arena.vercel.app,https://void-arena-six.vercel.app
CLIENT_ORIGIN=http://localhost:5173
